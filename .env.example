# ─────────────────────────────────────────────────────────────────────────────
#  RuralDocEnv — environment variable template
#  Copy to .env and fill in your values before running locally.
#
#      cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Supabase / psycopg3) ────────────────────────────────────────────
# Full connection string to your Supabase transaction pooler.
# Format: postgresql://[user]:[password]@[host]:[port]/[db]
SUPABASE_DB_URL=postgresql://postgres:mpd1wgrBMpD@db.kablgrbzoimfnshxrvjx.supabase.co:5432/postgres

# Connection pool sizing (optional — defaults shown)
# DB_POOL_MIN_SIZE=1
# DB_POOL_MAX_SIZE=10

# ─────────────────────────────────────────────────────────────────────────────
#  NLP pipeline (Input → Groq → Ollama → validate → migrate)
# ─────────────────────────────────────────────────────────────────────────────

# ── Stage 1: Groq prompt builder (optional) ──────────────────────────────────
# Used for fast Hinglish-cleanup + body-system hint before extraction.
# If GROQ_API_KEY is unset the pipeline still works — it just skips
# pre-processing and feeds raw text directly to Ollama.
# GROQ_API_KEY=gsk_...
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# GROQ_MODEL=llama-3.1-8b-instant

# ── Stage 2: Ollama structured extraction (recommended for dev) ──────────────
# Run `ollama serve` locally and `ollama pull llama3.1:8b-instruct-q4_K_M`.
# Any OpenAI-compatible /v1/chat/completions server works (vllm, etc.).
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.1:8b-instruct-q4_K_M
# OLLAMA_TIMEOUT_S=90
# OLLAMA_API_KEY=                # only needed if you put auth in front of Ollama

# ─────────────────────────────────────────────────────────────────────────────
#  Embeddings (rag/embeddings.py)
# ─────────────────────────────────────────────────────────────────────────────

# Run sentence-transformers locally — no API calls, no token, works offline.
# Pair with migration 003 (384-dim) and EMBED_MODEL below.
LOCAL_EMBED=1
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Alternative: hosted embeddings via HF or OpenAI-compatible TEI endpoint.
# EMBED_API_BASE_URL=https://router.huggingface.co/hf-inference
# EMBED_API_KEY=hf_...

# ─────────────────────────────────────────────────────────────────────────────
#  RL agent loop (env/inference.py)
# ─────────────────────────────────────────────────────────────────────────────
# The diagnostic agent shares the SAME local Ollama server as the extractor —
# zero extra cost. Leave these unset to inherit the Ollama defaults baked
# into env/inference.py:
#     API_BASE_URL = http://localhost:11434/v1
#     MODEL_NAME   = llama3.1:8b-instruct-q4_K_M
#
# Free alternative if your laptop can't run a local model:
#     API_BASE_URL=https://api.groq.com/openai/v1
#     MODEL_NAME=llama-3.1-8b-instant
#     # GROQ_API_KEY already set above
#
# Do NOT point this at OpenAI — paid endpoint.
# Do NOT point this at HuggingFace either — that burns the HF_TOKEN we want
# to keep in reserve for the GRPO training step.
# API_BASE_URL=
# MODEL_NAME=

# ─────────────────────────────────────────────────────────────────────────────
#  HuggingFace token — RESERVED FOR TRAINING
# ─────────────────────────────────────────────────────────────────────────────
# Only used by the future GRPO training script. Do NOT consume this on
# inference traffic — keep the quota available for fine-tuning.
HF_TOKEN=hf_hf_hqDnEJiRyADRAOGdNQwfObcIcWANJrgnQT
