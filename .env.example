# ─────────────────────────────────────────────────────────────────────────────
#  RuralDocEnv — environment variable template
#  Copy to .env and fill in your values before running locally.
#
#      cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Supabase / psycopg3) ────────────────────────────────────────────
# Full connection string to your Supabase transaction pooler.
# Format: postgresql://[user]:[password]@[host]:[port]/[db]
SUPABASE_DB_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Connection pool sizing (optional — defaults shown)
# DB_POOL_MIN_SIZE=1
# DB_POOL_MAX_SIZE=10

# ── LLM inference ─────────────────────────────────────────────────────────────
# API key — used as the bearer token for any OpenAI-compatible endpoint.
# For HuggingFace Inference API: https://huggingface.co/settings/tokens
HF_TOKEN=hf_...

# Base URL for the OpenAI-compatible inference endpoint.
# Leave at default to use OpenAI directly; override for HuggingFace / Ollama.
API_BASE_URL=https://api.openai.com/v1

# Model to use for the RuralDoc agent.
MODEL_NAME=gpt-4o-mini
